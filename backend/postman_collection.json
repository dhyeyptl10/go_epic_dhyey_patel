{
  "info": {
    "name": "Full Stack Backend API 2026",
    "_postman_id": "fullstack-backend-2026",
    "description": "Complete API collection for Full Stack Backend Project 2026.\n\n## Setup\n1. Import this collection in Postman\n2. Set `BASE_URL` variable to `http://localhost:5000`\n3. Run `npm run seed` to populate the DB\n4. Use login API to get token, set it as `TOKEN` variable\n\n## Test Credentials\n- **Admin**: admin@shop.com / Admin@123\n- **User**: rahul@example.com / Rahul@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:5000", "type": "string" },
    { "key": "TOKEN",    "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Server Health",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/health",
            "description": "Check server status and uptime"
          }
        },
        {
          "name": "API Root",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/",
            "description": "Get all available endpoints"
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test@123\",\n  \"phone\": \"9876543210\",\n  \"address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Ahmedabad\",\n    \"state\": \"Gujarat\",\n    \"pincode\": \"380001\"\n  }\n}"
            },
            "description": "Register a new user account"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["const res = pm.response.json();", "if (res.data && res.data.token) {", "  pm.collectionVariables.set('TOKEN', res.data.token);", "  console.log('Token saved!');", "}"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shop.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "description": "Login with admin credentials – auto-saves token"
          }
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"password\": \"Rahul@123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"9999999999\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@123\",\n  \"newPassword\": \"NewAdmin@123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "👥 Users (Admin)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/v1/users?page=1&limit=10",
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "role",   "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/users/USER_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/users/USER_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete User (Soft)",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/v1/users/USER_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Get User Stats (Aggregation)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/users/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "📂 Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/categories"
          }
        },
        {
          "name": "Get Category Stats (Aggregation)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/categories/stats"
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/categories/CATEGORY_ID_HERE"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Furniture\",\n  \"description\": \"Home and office furniture\",\n  \"slug\": \"furniture\"\n}"
            }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/categories/CATEGORY_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/v1/categories/CATEGORY_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "📦 Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/v1/products?page=1&limit=10",
              "query": [
                { "key": "page",      "value": "1" },
                { "key": "limit",     "value": "10" },
                { "key": "search",    "value": "",   "disabled": true },
                { "key": "category",  "value": "",   "disabled": true },
                { "key": "brand",     "value": "",   "disabled": true },
                { "key": "minPrice",  "value": "",   "disabled": true },
                { "key": "maxPrice",  "value": "",   "disabled": true },
                { "key": "minRating", "value": "",   "disabled": true },
                { "key": "inStock",   "value": "",   "disabled": true },
                { "key": "sort",      "value": "",   "disabled": true },
                { "key": "fields",    "value": "",   "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/products?search=iphone&page=1&limit=5"
          }
        },
        {
          "name": "Filter by Price Range",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/products?minPrice=500&maxPrice=5000&sort=price"
          }
        },
        {
          "name": "Sort by Rating (desc)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/products?sort=-ratings&limit=5"
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/products/featured?limit=4"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/products/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Get Product Stats (Aggregation, Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/products/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"OnePlus 12\",\n  \"description\": \"Flagship OnePlus with Snapdragon 8 Gen 3 and Hasselblad camera.\",\n  \"price\": 64999,\n  \"stock\": 40,\n  \"category\": \"CATEGORY_ID_HERE\",\n  \"brand\": \"OnePlus\",\n  \"ratings\": 4.6,\n  \"tags\": [\"smartphone\", \"oneplus\", \"android\", \"5g\"],\n  \"isFeatured\": true\n}"
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/products/PRODUCT_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 59999,\n  \"stock\": 35,\n  \"isFeatured\": true\n}"
            }
          }
        },
        {
          "name": "Delete Product (Admin, Soft)",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/v1/products/PRODUCT_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "🛒 Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"product\": \"PRODUCT_ID_HERE\", \"quantity\": 1 }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"123 Test Street\",\n    \"city\": \"Ahmedabad\",\n    \"state\": \"Gujarat\",\n    \"pincode\": \"380001\"\n  },\n  \"paymentMethod\": \"cod\"\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/orders/my-orders?page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/orders/ORDER_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/orders/ORDER_ID_HERE/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/orders?page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/v1/orders/ORDER_ID_HERE/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\",\n  \"paymentStatus\": \"paid\"\n}"
            }
          }
        },
        {
          "name": "Get Order Stats (Aggregation, Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/orders/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Delete Order (Admin, Soft)",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/v1/orders/ORDER_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    }
  ]
}
